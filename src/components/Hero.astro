---
import { DISCORD_USER_ID } from '../lib/projects.config';
---

<section class="hero" id="top">
  <div class="container">
    <div class="hero-inner">
      <p class="eyebrow">who am i</p>

      <h1 class="hero-title">
        <span class="prompt">~$</span>
        <span id="typed"></span><span class="cursor" aria-hidden="true">▌</span>
      </h1>

      <p class="hero-sub">
        Dmitriy, 16 y.o, Ukraine — building programs across way
        many languages, on purpose.
      </p>

      <div class="status-bar" id="lanyard-status" data-discord-id={DISCORD_USER_ID}>
        <div class="status-row status-row--loading">
          <span class="status-dot"></span>
          <span class="status-text">connecting to discord…</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="#projects" class="btn btn--primary">./view_projects</a>
        <a href="#contact" class="btn btn--ghost">./contact</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: 48px;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(232, 163, 61, 0.08), transparent),
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 100% 100%, 48px 48px, 48px 48px;
    mask-image: linear-gradient(to bottom, black, transparent 85%);
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
  }

  .prompt {
    color: var(--amber);
    margin-right: 14px;
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 8vw, 4.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 18px 0 22px;
    color: var(--ink-0);
    line-height: 1.05;
  }

  .cursor {
    color: var(--amber);
    animation: blink 1s step-end infinite;
    font-weight: 400;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .hero-sub {
    font-size: 1.02rem;
    color: var(--ink-1);
    max-width: 46ch;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .status-bar {
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 14px 18px;
    margin-bottom: 32px;
    max-width: 480px;
  }

  .status-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--status-offline);
    flex-shrink: 0;
  }

  .status-row--loading .status-dot {
    animation: pulse 1.4s ease-in-out infinite;
  }

  @keyframes pulse {
    50% {
      opacity: 0.3;
    }
  }

  .status-text {
    font-size: 0.88rem;
    color: var(--ink-1);
  }

  .status-detail {
    font-size: 0.8rem;
    color: var(--ink-2);
    margin: 4px 0 0 19px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease), background 0.2s var(--ease);
    display: inline-block;
  }

  .btn--primary {
    background: var(--amber);
    color: var(--bg-0);
  }

  .btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--amber-glow);
  }

  .btn--ghost {
    background: transparent;
    border: 1px solid var(--line-strong);
    color: var(--ink-0);
  }

  .btn--ghost:hover {
    background: var(--bg-2);
    transform: translateY(-2px);
  }
</style>

<script>
  const el = document.getElementById('typed');
  const word = 'xeraze';
  let i = 0;

  function type() {
    if (!el) return;
    if (i <= word.length) {
      el.textContent = word.slice(0, i);
      i++;
      setTimeout(type, 110);
    }
  }

  if (el) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = word;
    } else {
      type();
    }
  }
</script>

<script>
  import type { LanyardResponse } from '../types';

  const STATUS_LABEL: Record<string, string> = {
    online: 'online',
    idle: 'idle',
    dnd: 'do not disturb',
    offline: 'offline',
  };

  function formatElapsed(start: number): string {
    const diffMs = Date.now() - start;
    const h = Math.floor(diffMs / 3_600_000);
    const m = Math.floor((diffMs % 3_600_000) / 60_000);
    return h > 0 ? `${h}h ${m}m elapsed` : `${m}m elapsed`;
  }

  async function updateLanyard() {
    const container = document.getElementById('lanyard-status');
    if (!container) return;
    const discordId = container.dataset.discordId;

    try {
      const res = await fetch(`https://api.lanyard.rest/v1/users/${discordId}`);
      const json: LanyardResponse = await res.json();

      if (!json.success) throw new Error('lanyard request failed');

      const { discord_status, activities, listening_to_spotify, spotify } = json.data;

      const gameActivity = activities.find((a) => a.type === 0);

      let html = `
        <div class="status-row">
          <span class="status-dot" style="background: var(--status-${discord_status})"></span>
          <span class="status-text">${STATUS_LABEL[discord_status] ?? discord_status}</span>
        </div>
      `;

      if (listening_to_spotify && spotify) {
        html += `<p class="status-detail">🎧 ${spotify.song} — ${spotify.artist}</p>`;
      } else if (gameActivity) {
        html += `<p class="status-detail">👾 ${gameActivity.name}${gameActivity.details ? ` — ${gameActivity.details}` : ''}</p>`;
        if (gameActivity.timestamps?.start) {
          html += `<p class="status-detail">${formatElapsed(gameActivity.timestamps.start)}</p>`;
        }
      }

      container.innerHTML = html;
    } catch {
      container.innerHTML = `
        <div class="status-row">
          <span class="status-dot" style="background: var(--status-offline)"></span>
          <span class="status-text">status unavailable</span>
        </div>
      `;
    }
  }

  updateLanyard();
  setInterval(updateLanyard, 15000);
</script>
