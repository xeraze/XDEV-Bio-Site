---
const links = [
  { label: 'Telegram', href: 'https://t.me/xrzeoff', icon: 'telegram' },
  { label: 'GitHub', href: 'https://github.com/xeraze', icon: 'github' },
  { label: 'Email', href: 'mailto:xeraze.official@gmail.com', icon: 'email' },
];
---

<section id="contact">
  <div class="container">
    <p class="eyebrow">contact</p>
    <h2 class="section-title">Let's talk</h2>
    <p class="section-sub">
      Fastest response is on Discord. Everything else works too.
    </p>

    <div class="contact-grid">
      {links.map((link) => (
        <a class="contact-link" href={link.href} target="_blank" rel="noopener">
          <span class="contact-label">{link.label}</span>
          <span class="contact-arrow">↗</span>
        </a>
      ))}

      <button class="contact-link contact-link--btn" id="copy-discord">
        <span class="contact-label">Discord — xeraze.</span>
        <span class="contact-arrow" id="copy-icon">⧉</span>
      </button>
    </div>

    <a href="https://xeraze.github.io/Pricelist/" target="_blank" rel="noopener" class="pricelist-cta">
      view pricelist →
    </a>

    <p class="footer-note">built with astro · deployed on github pages</p>
  </div>
</section>

<div class="toast" id="toast">Copied "xeraze." to clipboard</div>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    font-weight: 600;
    margin: 10px 0 12px;
  }

  .section-sub {
    color: var(--ink-2);
    font-size: 0.88rem;
    margin-bottom: 32px;
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    text-decoration: none;
    color: var(--ink-0);
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
    width: 100%;
    text-align: left;
  }

  .contact-link:hover {
    border-color: var(--amber-dim);
    transform: translateX(4px);
  }

  .contact-arrow {
    color: var(--ink-2);
  }

  .pricelist-cta {
    display: inline-block;
    color: var(--amber);
    font-size: 0.9rem;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 64px;
  }

  .pricelist-cta:hover {
    text-decoration: underline;
  }

  .footer-note {
    color: var(--ink-2);
    font-size: 0.76rem;
    text-align: center;
  }

  .toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg-2);
    border: 1px solid var(--line-strong);
    color: var(--ink-0);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
    z-index: 200;
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  const btn = document.getElementById('copy-discord');
  const toast = document.getElementById('toast');

  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('xeraze.');
    } catch {
      // clipboard API can fail in insecure contexts; fail silently, toast still reassures visually
    }
    toast?.classList.add('show');
    setTimeout(() => toast?.classList.remove('show'), 2000);
  });
</script>
